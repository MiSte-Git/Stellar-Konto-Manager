{
  "name": "stellar-trustline-manager",
  "version": "1.0.0",
  "description": "A tool to manage Stellar trustlines",
  "main": "server.js",
  "scripts": {
    "// Hinweis": "// Für automatisches Build-Datum in Dev/Prod kann man beim Build Folgendes setzen: \\n//   VITE_BUILD_DATE=$(date -Iseconds) npm run dev \\n//   VITE_BUILD_DATE=$(date -Iseconds) npm run build \\n// Der Legal-Text liest dann import.meta.env.VITE_BUILD_DATE aus.",
    "start": "node server.js",
    "dev": "node scripts/start-dev.js",
    "start-build": "node scripts/start-build.js",
    "test": "node --test --test-isolation=none test/*.test.js",
    "test:trade": "node --test --test-isolation=none test/tradeService.test.js",
    "i18n:extract-glossary-keys": "node scripts/dev/extractGlossaryKeys.js",
    "i18n:sync-glossary": "node scripts/dev/syncGlossaryNamespace.mjs",
    "i18n:sync-learn": "node scripts/dev/syncLearnNamespace.mjs"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^16.0.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "proper-lockfile": "^4.1.2",
    "toml": "^3.0.0"
  },
  "overrides": {
    "axios": "^1.15.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "dotenv": "^16.0.0",
    "open": "^9.0.0"
  }
}
