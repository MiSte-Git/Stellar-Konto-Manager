# Blocks all direct HTTP access to this directory. multisig_jobs.json
# contains per-job access tokens and transaction XDRs; it must only ever
# be read/written by the PHP scripts in api/ via the filesystem, never
# served directly by the webserver.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
