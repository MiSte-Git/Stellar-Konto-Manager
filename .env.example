# Local configuration (not tracked). Copy to ".env" and fill with real values.
BACKEND_PORT=3000
FRONTEND_PORT=5173
HORIZON_URL=https://horizon.stellar.org
# Bugtracker admin login secret, checked server-side only (never sent to the
# frontend/JS bundle). Set the same value in api/_config.php's
# BUGTRACKER_ADMIN_SECRET if you also run the PHP backend variant.
BUGTRACKER_ADMIN_SECRET=<set-me>
# Signs the admin session cookie; any random string, rotate to invalidate all sessions.
SESSION_SECRET=<set-me>
# Use prod API when you want to talk to cyon backend; leave empty for local.
PROD_API_URL=https://www.skm.steei.de
